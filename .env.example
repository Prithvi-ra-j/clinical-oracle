# Clinical Oracle Environment Variables
# Copy this file to .env and fill in your actual values

# Required: Groq API key for LLM risk scoring
# Get from: https://console.groq.com
GROQ_API_KEY=

# Optional: FHIR server base URL
# Default: https://hapi.fhir.org/baseR4
FHIR_BASE_URL=https://hapi.fhir.org/baseR4

# Optional: FAERS API base URL
# Default: https://api.fda.gov/drug/event.json
FAERS_BASE_URL=https://api.fda.gov/drug/event.json

# Optional: Server port (set automatically by Railway)
PORT=8000
